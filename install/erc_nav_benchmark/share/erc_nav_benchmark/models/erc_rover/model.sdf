<?xml version="1.0"?>
<sdf version="1.6">
  <model name="erc_rover">

    <pose>0 0 0.18 0 0 0</pose>

    <!-- ============================
         CHASSIS
    ============================ -->
    <link name="base_link">
      <inertial>
        <mass>8.0</mass>
        <inertia>
          <ixx>0.2</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.3</iyy><iyz>0</iyz>
          <izz>0.4</izz>
        </inertia>
      </inertial>

      <!-- Chassis collision -->
      <collision name="chassis_collision">
        <geometry><box><size>0.55 0.35 0.15</size></box></geometry>
        <surface>
          <friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction>
        </surface>
      </collision>

      <!-- Chassis visual -->
      <visual name="chassis_visual">
        <geometry><box><size>0.55 0.35 0.15</size></box></geometry>
        <material>
          <ambient>0.2 0.5 0.8 1</ambient>
          <diffuse>0.2 0.5 0.8 1</diffuse>
        </material>
      </visual>

      <!-- Top sensor box -->
      <visual name="sensor_box">
        <pose>0.05 0 0.12 0 0 0</pose>
        <geometry><box><size>0.15 0.12 0.10</size></box></geometry>
        <material>
          <ambient>0.8 0.3 0.1 1</ambient>
          <diffuse>0.8 0.3 0.1 1</diffuse>
        </material>
      </visual>

    </link>

    <!-- Dedicated Front Bumper Link with Contact Sensor -->
    <link name="front_bumper">
      <pose>0.28 0 0.18 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.001</iyy><iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <collision name="bumper_collision">
        <geometry><box><size>0.02 0.35 0.15</size></box></geometry>
      </collision>
      <visual name="bumper_visual">
        <geometry><box><size>0.02 0.35 0.15</size></box></geometry>
        <material>
          <ambient>0.8 0.1 0.1 1</ambient>
          <diffuse>0.8 0.1 0.1 1</diffuse>
        </material>
      </visual>

      <sensor name="bumper_sensor" type="contact">
        <contact>
          <collision>bumper_collision</collision>
        </contact>
        <plugin name="gazebo_ros_bumper" filename="libgazebo_ros_bumper.so">
          <ros>
            <namespace>/</namespace>
            <remapping>bumper_states:=bumper_states</remapping>
          </ros>
          <frame_name>front_bumper</frame_name>
        </plugin>
        <always_on>true</always_on>
        <update_rate>100</update_rate>
      </sensor>
    </link>

    <joint name="joint_bumper" type="fixed">
      <parent>base_link</parent>
      <child>front_bumper</child>
    </joint>

    <!-- ============================
         WHEELS (4x)
    ============================ -->

    <!-- Front Left Wheel -->
    <link name="wheel_fl">
      <pose>0.20 0.22 -0.05 -1.5707 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.003</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.003</iyy><iyz>0</iyz><izz>0.005</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.09</radius><length>0.06</length></cylinder></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.09</radius><length>0.06</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
    </link>
    <joint name="joint_fl" type="revolute">
      <parent>base_link</parent><child>wheel_fl</child>
      <axis><xyz>0 0 1</xyz><dynamics><friction>0.1</friction></dynamics></axis>
    </joint>

    <!-- Front Right Wheel -->
    <link name="wheel_fr">
      <pose>0.20 -0.22 -0.05 -1.5707 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.003</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.003</iyy><iyz>0</iyz><izz>0.005</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.09</radius><length>0.06</length></cylinder></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.09</radius><length>0.06</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
    </link>
    <joint name="joint_fr" type="revolute">
      <parent>base_link</parent><child>wheel_fr</child>
      <axis><xyz>0 0 1</xyz><dynamics><friction>0.1</friction></dynamics></axis>
    </joint>

    <!-- Rear Left Wheel -->
    <link name="wheel_rl">
      <pose>-0.20 0.22 -0.05 -1.5707 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.003</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.003</iyy><iyz>0</iyz><izz>0.005</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.09</radius><length>0.06</length></cylinder></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.09</radius><length>0.06</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
    </link>
    <joint name="joint_rl" type="revolute">
      <parent>base_link</parent><child>wheel_rl</child>
      <axis><xyz>0 0 1</xyz><dynamics><friction>0.1</friction></dynamics></axis>
    </joint>

    <!-- Rear Right Wheel -->
    <link name="wheel_rr">
      <pose>-0.20 -0.22 -0.05 -1.5707 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.003</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.003</iyy><iyz>0</iyz><izz>0.005</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.09</radius><length>0.06</length></cylinder></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.09</radius><length>0.06</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
    </link>
    <joint name="joint_rr" type="revolute">
      <parent>base_link</parent><child>wheel_rr</child>
      <axis><xyz>0 0 1</xyz><dynamics><friction>0.1</friction></dynamics></axis>
    </joint>

    <!-- ============================
         DIFFERENTIAL DRIVE PLUGIN
    ============================ -->
    <plugin name="differential_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>

      <num_wheel_pairs>2</num_wheel_pairs>

      <!-- Wheels -->
      <left_joint>joint_fl</left_joint>
      <left_joint>joint_rl</left_joint>
      <right_joint>joint_fr</right_joint>
      <right_joint>joint_rr</right_joint>

      <!-- Kinematics -->
      <wheel_separation>0.44</wheel_separation>
      <wheel_diameter>0.18</wheel_diameter>

      <!-- Limits -->
      <max_wheel_torque>100</max_wheel_torque>
      <max_wheel_acceleration>5.0</max_wheel_acceleration>

      <!-- Output -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>

  </model>
</sdf>
